{
    "name": "Scars Watch Campaign",
    "image": "mcr.microsoft.com/devcontainers/python:1-3.11",
    "features": {
        "ghcr.io/devcontainers/features/git:1": {}
    },
    "postCreateCommand": "pip install -e . && pip install -r requirements.txt",
    "customizations": {
        "codespaces": {
            "openFiles": [
                "README.md",
                "app.py"
            ]
        },
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff"
            ],
            "settings": {
                "python.defaultInterpreterPath": "${containerEnv:PYTHON_PATH}",
                "python.linting.enabled": true,
                "python.linting.ruffEnabled": true,
                "[python]": {
                    "editor.defaultFormatter": "ms-python.python",
                    "editor.formatOnSave": true
                }
            }
        }
    },
    "forwardPorts": [5000],
    "portsAttributes": {
        "5000": {
            "label": "Flask App",
            "onAutoForward": "notify"
        }
    },
    "remoteEnv": {
        "FLASK_APP": "app.py",
        "FLASK_ENV": "development"
    }
}
